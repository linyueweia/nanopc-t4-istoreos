# iStoreOS NanoPC-T4 编译配置
# 目标设备: FriendlyARM NanoPC-T4 (RK3399)
# 基于: istoreos-24.10 分支

# ===========================
# 目标系统 - 仅 NanoPC-T4
# ===========================
CONFIG_TARGET_rockchip=y
CONFIG_TARGET_rockchip_armv8=y
CONFIG_TARGET_rockchip_armv8_DEVICE_friendlyarm_nanopc-t4=y

# ===========================
# 系统基础配置
# ===========================
CONFIG_ARCH="aarch64"
CONFIG_TARGET_OPTIONS=y
CONFIG_TARGET拱面_rockchip_armv8=y

# ===========================
# iStoreOS 核心
# ===========================
CONFIG_PACKAGE_istoreos-files=y
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-base=y
CONFIG_PACKAGE_luci-compat=y
CONFIG_PACKAGE_luci-lib-ipkg=y

# 中文语言
CONFIG_PACKAGE_luci-i18n-base-zh-cn=y

# ===========================
# NanoPC-T4 硬件支持
# ===========================
# WiFi (板载 AP6356S)
CONFIG_PACKAGE_kmod-brcmfmac=y
CONFIG_PACKAGE_brcmfmac-nvram-4356-sdio=y
CONFIG_PACKAGE_cypress-firmware-4356-sdio=y

# NVMe SSD
CONFIG_PACKAGE_kmod-nvme=y

# USB 存储
CONFIG_PACKAGE_kmod-usb-storage=y
CONFIG_PACKAGE_kmod-usb-storage-extras=y

# 文件系统
CONFIG_PACKAGE_kmod-fs-ext4=y
CONFIG_PACKAGE_kmod-fs-vfat=y
CONFIG_PACKAGE_e2fsprogs=y

# ===========================
# 网络配置
# ===========================
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_wget=y
CONFIG_PACKAGE_openssh-sftp-server=y

# 防火墙
CONFIG_PACKAGE_firewall4=y

# ===========================
# Docker 支持 (可选)
# ===========================
CONFIG_PACKAGE_dockerd=y
CONFIG_PACKAGE_containerd=y
CONFIG_PACKAGE_runc=y
CONFIG_PACKAGE_luci-app-dockerman=y

# ===========================
# LuCI 应用
# ===========================
CONFIG_PACKAGE_luci-app-zerotier=y
CONFIG_PACKAGE_luci-app-openvpn=y

# ===========================
# 编译优化
# ===========================
CONFIG_DEVEL=y
CONFIG_CCACHE=y
CONFIG_CCACHE_DIR=".ccache"
